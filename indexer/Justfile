set fallback

import '../tools/lib/utils.justfile'

# Default: show available recipes
default:
    just --list

build:
    docker build --network=host -f Dockerfile -t indexer:latest ..

build-replay:
    cd .. && go build --network=host -o indexer/bin/indexer-replay ./indexer/cmd/replay/main.go

build-rc:
    docker build --network=host -f Dockerfile -t indexer:rc ..

build-dev:
    docker build --network=host -f Dockerfile.dev -t indexer:dev ..

publish-rc registry version:
    docker tag indexer:rc {{registry}}/containers/chainlink-ccv-indexer:{{version}}-rc
    docker push {{registry}}/containers/chainlink-ccv-indexer:{{version}}-rc

clean:
    docker rmi indexer:latest

clean-dev:
    docker rmi indexer:dev

create-migration name:
    goose create {{name}} sql -dir ./migrations
